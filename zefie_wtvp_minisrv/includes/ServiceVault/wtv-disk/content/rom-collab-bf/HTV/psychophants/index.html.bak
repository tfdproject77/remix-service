document.write('</TD>')



document.write('<TD ALIGN=center>')

document.write('<IMG SRC="62.gif" WIDTH=40 HEIGHT=15 BORDER=0></A>')

document.write('</TD>')



document.write('<TD ALIGN=center>')

document.write('<IMG SRC="62.gif" WIDTH=130 HEIGHT=15><IMG SRC="62.gif" WIDTH=30 HEIGHT=15><IMG SRC="62.gif" WIDTH=30 HEIGHT=15>')

document.write('</TD>')

document.write('</TR>')



document.write('<TR>')

document.write('<TD ALIGN=center>')

document.write('<IMG SRC="60.gif" WIDTH=130 HEIGHT=15><IMG SRC="51.gif" WIDTH=30 HEIGHT=15>')

document.write('</TD>')



document.write('<TD ALIGN=center>')

document.write('<A HREF="Javascript:void(0)" onmouseover="move(4)" selected><IMG SRC="d4.gif" WIDTH=40 HEIGHT=15 BORDER=0></A>')

document.write('</TD>')



document.write('<TD ALIGN=center>')

document.write('<FORM name="helm">')

document.write('<input type="button" ONCLICK="move(0)" value="STOP" name="cent">')

document.write('</FORM>')

document.write('</TD>')



document.write('<TD ALIGN=center>')

document.write('<A HREF="Javascript:void(0)" onmouseover="move(2)"><IMG SRC="d4.gif" WIDTH=40 HEIGHT=15 BORDER=0></A>')

document.write('</TD>')



document.write('<TD ALIGN=center>')

document.write('<IMG SRC="60.gif" WIDTH=130 HEIGHT=15><IMG SRC="52.gif" WIDTH=30 HEIGHT=15>')

document.write('</TD>')

document.write('</TR>')



document.write('<TR>')

document.write('<TD ALIGN=center>')

document.write('<IMG SRC="60.gif" WIDTH=130 HEIGHT=15><IMG SRC="53.gif" WIDTH=30 HEIGHT=15>')

document.write('</TD>')



document.write('<TD ALIGN=center>')

document.write('<IMG SRC="62.gif" WIDTH=40 HEIGHT=15 BORDER=0></A>')

document.write('</TD>')



document.write('<TD ALIGN=center>')

document.write('<A HREF="Javascript:void(0)" onmouseover="move(3)"><IMG SRC="d4.gif" WIDTH=40 HEIGHT=15 BORDER=0></A>')

document.write('</TD>')



document.write('<TD ALIGN=center>')

document.write('<IMG SRC="62.gif" WIDTH=40 HEIGHT=15 BORDER=0></A>')

document.write('</TD>')



document.write('<TD ALIGN=center>')

document.write('<IMG SRC="60.gif" WIDTH=130 HEIGHT=15><IMG SRC="54.gif" WIDTH=30 HEIGHT=15>')

document.write('</TD>')

document.write('</TR>')

document.write('</TABLE>')

</script>

