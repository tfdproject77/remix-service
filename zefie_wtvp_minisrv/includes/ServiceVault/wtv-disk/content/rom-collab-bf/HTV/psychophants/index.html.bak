<!-- REVISED  --- Edited by MattMan as some assets were missing such as sound and images some functions needed to be adjusted-->
<script language="Javascript">


delay = 10

rob = new Image()

rob.src = "1.gif"

ry = 14

rx = 8

dir = 0

thing = new Array()

things = 0

each = 0

fire=15

burn = 0

hot = 8

hit = 0

vap = 1

exp = 0

off = 0

end = 0

sin = 0

out = 10

x0 = 0

x1 = 0

x2 = 0



room = new Array()

room[0] =  new Array(24,20,20,20,20,24,20,20,24,20,20,20,20,27,20,20,20,20,27,20,27,20,20,20,20,27)

room[1] =  new Array(21, 0, 0, 0, 0,21, 0, 0,21, 0, 0, 0, 0,43, 0, 0, 0, 0,23, 0,23, 0, 0, 0, 0,23)

room[2] =  new Array(21, 6, 0,29, 0,21, 0, 0,21, 0, 0, 0, 0, 0, 0, 0,44,20,28, 0,23, 0,35, 0, 9,23)

room[3] =  new Array(24,20,20,36, 0,21, 0, 0,32,40, 0,44,20,27, 0, 0, 0, 0, 0, 0,23, 0,39,20,20,27)

room[4] =  new Array(21, 0, 0, 0, 0,21, 0, 0, 0, 0, 0, 0, 0,23, 0, 0, 0, 0,35, 0,23, 0, 0, 0, 0,23)

room[5] =  new Array(24,40, 0,32,20,36, 0, 0,29, 0,24,20,20,20,20,27, 0, 0,23, 0,39,20,28, 0,44,27)

room[6] =  new Array(21, 0, 0, 0, 0, 0, 0, 0,21, 0,21,24,20,20,27,23, 0, 0,23, 0, 0, 0, 0, 0, 0,23)

room[7] =  new Array(24,20,20,20,40, 0,32,24,20,20,21,21,14,17,23,23, 0, 0,23, 0, 0, 0, 0, 0, 0,23)

room[8] =  new Array(21, 0, 0, 0, 0, 0, 0,21, 0, 0,21,21,15,16,23,23,22,22,26,34, 0,42,22,22,22,26)

room[9] =  new Array(21, 0, 0, 0, 0, 0, 0,21, 0, 0,21,25,22,22,26,23, 0,23, 0, 0, 0, 0, 0, 0, 0,23)

room[10] = new Array(25,46, 0,30,22,37, 0,21, 0, 0,25,22,22,22,22,26, 0,31, 0, 0,38,22,34, 0,42,26)

room[11] = new Array(21, 0, 0, 0, 0,21, 0,33, 0, 0, 0, 0,21, 0, 0, 0, 0, 0, 0, 0,23, 0, 0, 0, 0,23)

room[12] = new Array(25,22,22,37, 0,21, 0, 0, 0, 0, 0, 0,25,22,46, 0,42,34, 0, 0,23, 0,38,22,22,26)

room[13] = new Array(21, 7, 0,33, 0,21, 0,30,22,46, 0, 0, 0, 0, 0, 0, 0,23, 0, 0,23, 0,31, 0, 8,23)

room[14] = new Array(21, 0, 0, 0, 0,21, 0,21, 0, 0, 0, 0,41, 0, 0, 0, 0,23, 0, 0,23, 0, 0, 0, 0,23)

room[15] = new Array(25,22,22,22,22,25,22,25,22,22,22,22,25,22,22,22,22,26,22,22,26,22,22,22,22,26)



function build() {

	f = 0

	for(y=0;y<16;y++) {

		for(x=0;x<26;x++) {

			if(y>0 && y<15 && x>0 && x<25) {

				if(f<40 & room[y][x] == 0 & Math.round(10*Math.random())==5) {

					thing[f] = y

					thing[f+1] = x

					//thing[f+2] = 0

					room[y][x] = 5

					f+=2

				}

			}

			document.images[(y*26)+x].src = room[y][x]+".gif"

		}

	}

	things = thing.length

	moving = setTimeout("runner()",2000)

}



function endgame() {

	if(sin == 0) {

		//document.embeds[4].play()
        PlaySound(document.win)

		document.images[425].src = "63.gif"

		document.images[430].src = "62.gif"

		document.images[432].src = "62.gif"

		document.images[437].src = "62.gif"

	}

	else {

		document.images[425].src = "62.gif"

		document.images[430].src = "62.gif"

		document.images[432].src = "62.gif"

		document.images[437].src = "62.gif"

	}

	sin = 1-sin

	out--

	if(out>0) setTimeout("endgame()",1500)

	else document.location = "index.html"

}



function game() {

	clearTimeout(moving)

	end=1

	document.images[(7*26)+12].src = "0.gif"

	document.images[(7*26)+13].src = "0.gif"

	document.images[(8*26)+12].src = "0.gif"

	document.images[(8*26)+13].src = "0.gif"

	for(y=0;y<16;y++) {

		for(x=0;x<26;x++) {

			if(room[y][x]==5) document.images[(y*26)+x].src = "0.gif"

		}

	}

	document.images[426].src = "62.gif"

	document.images[431].src = "62.gif"

	document.images[433].src = "62.gif"

	document.images[438].src = "62.gif"

	endgame()

}



function shutdown() {

	if(ry==2 && rx==2 && room[2][1]==6) {

		room[2][1] = 10

		document.images[(2*26)+1].src = "10.gif"

		document.images[425].src = "62.gif"

		document.images[426].src = "62.gif"

		off++

		if(exp>0&&exp<52) exp++

		//document.embeds[3].play()
        PlaySound(document.off)

	}

	else if(ry==13 && rx==2 && room[13][1]==7) {

		room[13][1] = 11

		document.images[(13*26)+1].src = "11.gif"

		document.images[432].src = "62.gif"

		document.images[433].src = "62.gif"

		off++

		if(exp>0&&exp<52) exp++

		//document.embeds[3].play()
        PlaySound(document.off)

	}

	else if(ry==13 && rx==23 && room[13][24]==8) {

		room[13][24] = 12

		document.images[(13*26)+24].src = "12.gif"

		document.images[437].src = "62.gif"

		document.images[438].src = "62.gif"

		off++

		if(exp>0&&exp<52) exp++

		//document.embeds[3].play()
        PlaySound(document.off)

	}

	else if(ry==2 && rx==23 && room[2][24]==9) {

		room[2][24] = 13

		document.images[(2*26)+24].src = "13.gif"

		document.images[430].src = "62.gif"

		document.images[431].src = "62.gif"

		off++

		if(exp>0&&exp<52) exp++

		//document.embeds[3].play()
        PlaySound(document.off)

	}

	dir = 0

	if(off==4) game()

}



function vapor() {

	clearTimeout(moving)

	if(vap==1) PlaySound(document.dead)

	room[ry][rx] = vap

	document.images[(ry*26)+rx].src = vap+".gif"

	vap++

	if(vap<6) dissolve = setTimeout("vapor()",200)

	else {

		vap = 1

		ry = 14

		rx = 8

		dir = 0

		document.images[(ry*26)+rx].src = "1.gif"

		moving = setTimeout("runner()",500)

	}

}



function setexp() {

	if(exp==0) {

		document.images[416].src = "61.gif"

		document.images[417].src = "53.gif"

		document.images[418].src = "50.gif"

		document.images[422].src = "61.gif"

		document.images[423].src = "53.gif"

		document.images[424].src = "50.gif"

		exp = 53

		cnt = 50

	}

}



function explode() {

	if(exp>0) {

        PlaySound(document.tick)
		//document.embeds[2].play()

		document.images[417].src = exp+".gif"

		document.images[418].src = cnt+".gif"

		document.images[423].src = exp+".gif"

		document.images[424].src = cnt+".gif"

		cnt--

		if(cnt==49) {

			exp--

			if(exp==49)	{

				clearTimeout(moving)

				dir=0

				document.location = "boom.html"

			}

			else cnt = 59

		}

	}

}



function walk() {

	hit = 0

	document.images[(ry*26)+rx].src = "0.gif"

	if(dir==1) {

		hit = room[ry-1][rx]

		if(hit==0||hit==5) ry = ry-1

	}

	else if(dir==2) {

		hit = room[ry][rx+1]

		if(hit==0||hit==5) rx = rx+1

	}

	else if(dir==3) {

		hit = room[ry+1][rx]

		if(hit==0||hit==5) ry = ry+1

	}

	else if(dir==4) {

		hit = room[ry][rx-1]

		if(hit==0||hit==5) rx = rx-1

	}

	document.images[(ry*26)+rx].src = rob.src

	if(hit==5) dissolve = setTimeout("vapor()",200)

	if(hit>5 && hit<10) shutdown()

}



function creep() {

	ty = 0

	tx = 0

	tz = 0

	x = each

	shape = 5

	c = Math.round(39*Math.random()+1)

	document.images[(thing[x]*26)+thing[x+1]].src = "5.gif"

	if(c>30) {

		if(thing[x]>1) ty = -1

	}

	else if(c>20) {

		if(thing[x+1]<24) tx = 1

	}

	else if(c>10) {

		if(thing[x]<14) ty = 1

	}

	else {

		if(thing[x+1]>1) tx = -1

	}

	if(room[thing[x]+ty][thing[x+1]+tx] < 6)	{

		document.images[(thing[x]*26)+thing[x+1]].src = "0.gif"

		room[thing[x]][thing[x+1]] = 0

		thing[x] += ty

		thing[x+1] += tx

		document.images[(thing[x]*26)+thing[x+1]].src = "5.gif"

		room[thing[x]][thing[x+1]] = 5

	}

	else if(room[thing[x]+ty][thing[x+1]+tx]>19) {

		if(room[thing[x]-ty][thing[x+1]-tx] == 5 || burn > hot) {

			document.images[(thing[x]*26)+thing[x+1]].src = "0.gif"

			room[thing[x]][thing[x+1]] = 0

			thing[x] += ty

			thing[x+1] += tx

			document.images[(thing[x]*26)+thing[x+1]].src = "18.gif"

			room[thing[x]][thing[x+1]] = 5

            //PlaySound(document.sear) slows box down

			burn = 0

		}

		else burn++

	}

	if(thing[x]==6) {

		if(thing[x+1]>10) {

			if(thing[x+1]<15) setexp()

		}

	}

	else if(thing[x]==9) {

		if(thing[x+1]>10) {

			if(thing[x+1]<15) setexp()

		}

	}

	else if(thing[x+1]==11) {

		if(thing[x]>5) {

			if(thing[x]<10) setexp()

		}

	}

	else if(thing[x+1]==14) {

		if(thing[x]>5) {

			if(thing[x]<10) setexp()

		}

	}

	each += 2

	if(each > things-1) each = 0

}



function runner() {

	clearTimeout(moving)

	delay--

	if(delay==2) walk()

	else if(delay==7) walk()

	else if(delay==0) {

		delay = 10

		if(end==0) explode()

		fire--

		if(fire==0) {

			fire=15

			hot--

		}

	}

	else creep()

	if(end==0) moving = setTimeout("runner()",100)

}



function move(d) {

	dir = d; document.helm.cent.focus()

}

function PlaySound(sound) {
if (sound == null) {  
return;
} else {
sound.play(false);
}
}

</script>


</head>
<body bgcolor="#000000" text="#ffffff" onload="build()">


<script language="Javascript">

document.write('<TABLE CELLSPACING=0 CELLPADDING=0 ALIGN=CENTER BORDER=0>')

document.write('<TR>')

document.write('<TD ALIGN=CENTER COLSPAN=5>')

for(x=0;x<16;x++) {

	for(y=0;y<26;y++) {

		document.write('<IMG SRC="0.gif" WIDTH=20 HEIGHT=20>')

	}

	document.write('<BR>')

}

document.write('</TD>')

document.write('</TR>')



document.write('<TR>')

document.write('<TD ALIGN=center>')

document.write('<IMG SRC="62.gif" WIDTH=130 HEIGHT=15><IMG SRC="62.gif" WIDTH=30 HEIGHT=15><IMG SRC="62.gif" WIDTH=30 HEIGHT=15>')

document.write('</TD>')

document.write('<TD ALIGN=center>')

